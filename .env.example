# CV Builder — Environment Config
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── API Keys (get one from platform.openai.com or console.anthropic.com) ──
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Model config ──────────────────────────────────────────────────────────
CV_API_PROVIDER=openai
CV_API_MODEL=gpt-4o-mini

# ── Paths ─────────────────────────────────────────────────────────────────
CV_BUILD_PATH=C:\Users\YourName\CV_Build

# ── Google Sheets webhook (created during setup) ──────────────────────────
CV_SHEETS_WEBHOOK=
